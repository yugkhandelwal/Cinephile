# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git - it contains sensitive information

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# TMDB API Configuration
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_API_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# Optional: Analytics (if you add analytics)
# VITE_GA_TRACKING_ID=your_google_analytics_id
# VITE_PLAUSIBLE_DOMAIN=your_domain.com
